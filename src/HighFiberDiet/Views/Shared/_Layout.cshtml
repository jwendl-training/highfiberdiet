<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - High Fiber Diet</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <input type="checkbox" id="dark-mode-toggle" class="dark-mode-checkbox" />
    <div id="page-wrapper">
        <header>
            <nav class="navbar navbar-expand-sm navbar-dark app-navbar">
                <div class="container">
                    <a class="navbar-brand text-white fw-bold" asp-area="" asp-controller="Home" asp-action="Index">🥦 High Fiber Diet</a>
                    <div class="navbar-collapse d-flex align-items-center">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Foods" asp-action="Index">Foods</a>
                            </li>
                        </ul>
                        <label for="dark-mode-toggle" class="theme-toggle-btn ms-2">
                            <span class="theme-toggle-light">🌙 Dark</span>
                            <span class="theme-toggle-dark">☀️ Light</span>
                        </label>
                    </div>
                </div>
            </nav>
        </header>
        <div class="container mt-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted mt-4">
            <div class="container py-3">
                &copy; 2026 - High Fiber Diet
            </div>
        </footer>
    </div>
</body>
</html>
