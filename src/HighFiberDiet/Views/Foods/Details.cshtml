@model HighFiberDiet.Models.Food

@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Foods" asp-action="Index">Foods</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="food-detail">
    <div class="food-detail-image-container">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="food-detail-image" />
        }
        else if (System.IO.File.Exists(System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "images", "foods", Model.ImageFileName)))
        {
            <img src="~/images/foods/@Model.ImageFileName" alt="@Model.Name" class="food-detail-image" />
        }
        else
        {
            <div class="food-detail-placeholder">
                <span>🥗</span>
                <p>Image not available</p>
            </div>
        }
    </div>
    <div class="food-detail-info">
        <h1>@Model.Name</h1>
        <p class="food-detail-fiber">
            <strong>Fiber:</strong> @Model.FiberAmountGrams g per 100 g
        </p>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="food-detail-description">@Model.Description</p>
        }
        <a asp-controller="Foods" asp-action="Index" class="btn btn-outline-success mt-3">← Back to Foods</a>
    </div>
</div>
