@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 text-success">🥦 High Fiber Diet</h1>
    <p class="lead mt-3">Discover foods that are high in dietary fiber and learn how they can benefit your health.</p>
    <a asp-controller="Foods" asp-action="Index" class="btn btn-success btn-lg mt-3">Browse High Fiber Foods</a>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <h3>Why Fiber Matters</h3>
        <p>Dietary fiber supports digestive health, helps maintain a healthy weight, and lowers the risk of diabetes and heart disease.</p>
    </div>
    <div class="col-md-4">
        <h3>How Much Do You Need?</h3>
        <p>Adults should aim for 25–38 grams of dietary fiber per day. Most people only get about half of that amount.</p>
    </div>
    <div class="col-md-4">
        <h3>Top Fiber Sources</h3>
        <p>Legumes, whole grains, fruits, vegetables, nuts, and seeds are all excellent sources of dietary fiber.</p>
    </div>
</div>
